---
// The SVF lesson page (T032). Loads the `lesson.mdx` content-collection entry,
// renders its six-part body inside the bench/lab-manual shell, and lets the
// embedded <Artifact> islands + build-time resolver do their work.
//
// The MDX body owns the six parts (Concept, Hear it, Observe it, Play with it,
// Build it with acfx, Go deeper) and embeds both live artifacts by typed
// declaration; this page just supplies the hero copy from frontmatter and the
// surrounding layout.
import { getEntry, render } from 'astro:content';
import LessonLayout from '@components/lesson/LessonLayout.astro';

const lesson = await getEntry('lessons', 'lesson');
if (lesson === undefined) {
  throw new Error(
    'SVF lesson content entry "lesson" not found in the `lessons` collection ' +
      '(expected site/src/content/svf/lesson.mdx).',
  );
}

const { Content } = await render(lesson);
const { title, description, eyebrow } = lesson.data;
---

<LessonLayout title={title} eyebrow={eyebrow} thesis={description}>
  <Content />
</LessonLayout>
