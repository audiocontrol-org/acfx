---
// LessonLayout — the "bench & lab manual" page shell that frames the SVF
// lesson (frontend-design, Commandment IV / FR-016).
//
// Direction: the two interactive artifacts are lit analog INSTRUMENTS; this
// page is the dark workbench they rest on plus the engineer's lab manual. The
// manual voice is a real reading serif at a comfortable measure; the instrument
// voice — eyebrows, section kickers, data, file paths — stays the engraved
// monospace of the faceplates. One warm signal-amber accent, inherited from
// the instruments, carries the SIGNATURE: a vertical "signal rail" down the
// left of the column that links the six numbered stations and warms toward
// amber-hot through the hands-on sections (Play / Build), echoing the
// instruments' resonance-heat glow so page and instruments read as one system.
//
// Pure presentation: no DSP, no data access. The page (`index.astro`) resolves
// content + metadata and slots it in.
//
// TABBED layout (frontend-design): the six parts are one ordered procedure, so
// the vertical "signal rail" that once linked them became a horizontal
// channel-selector TAB BANK — engraved push-buttons with a station index
// (01..06) and an amber LED, seated on a raised faceplate over the rail
// gradient, rotated flat into a "signal bus". The two hands-on tabs (Play /
// Build) run warm (resonance-heat). The bank is sticky so the whole structure
// stays visible/navigable while reading; it scrolls horizontally on narrow
// screens. Tab semantics + hash deep-linking live in `lesson-tabs.ts`.
import type { LessonPartTab } from '../../content/svf/lesson-parts.ts';

interface Props {
  readonly title: string;
  readonly eyebrow: string;
  readonly thesis: string;
  readonly tabs: readonly LessonPartTab[];
}

const { title, eyebrow, thesis, tabs } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={thesis} />
    <title>{title}</title>
  </head>
  <body>
    <div class="bench">
      <main class="lesson">
        <header class="lesson__hero">
          <p class="lesson__eyebrow">{eyebrow}</p>
          <h1 class="lesson__title">{title}</h1>
          <p class="lesson__thesis">{thesis}</p>

          <!-- Signature glyph: one input branches to three simultaneous taps —
               the characteristic thing about a state-variable filter. -->
          <div class="lesson__taps" aria-hidden="true">
            <span class="lesson__tap-in">in</span>
            <span class="lesson__tap-fan"></span>
            <span class="lesson__tap-out">LP</span>
            <span class="lesson__tap-out">BP</span>
            <span class="lesson__tap-out">HP</span>
          </div>
        </header>

        <nav class="tabs" aria-label="Lesson parts">
          <div class="tabs__scroll" data-lesson-tabs-scroll>
            <div class="tabs__bank" role="tablist" aria-label="Lesson parts" data-lesson-tabs>
              {
                tabs.map((tab, i) => (
                  <button
                    class:list={['tab', { 'tab--hot': tab.hot }]}
                    id={`${tab.id}-tab`}
                    type="button"
                    role="tab"
                    aria-controls={tab.id}
                    aria-selected={i === 0 ? 'true' : 'false'}
                    tabindex={i === 0 ? 0 : -1}
                  >
                    <span class="tab__meta" aria-hidden="true">
                      <span class="tab__led" />
                      <span class="tab__index">{String(i + 1).padStart(2, '0')}</span>
                    </span>
                    <span class="tab__label">{tab.label}</span>
                  </button>
                ))
              }
            </div>
          </div>
          <div class="tabs__bus" aria-hidden="true"></div>
        </nav>

        <div class="lesson__body">
          <slot />
        </div>

        <script>
          import { initLessonTabs } from './lesson-tabs.ts';
          initLessonTabs();
        </script>

        <footer class="lesson__foot">
          <p class="lesson__foot-line">
            Every sound, plot, and checkpoint on this page comes from the real
            acfx SVF — the same code that runs on the desktop and the
            microcontroller. Nothing here is a reimplementation.
          </p>
        </footer>
      </main>
    </div>

    <style is:global>
      :root {
        --void: #0f1219;
        --face: #161b26;
        --raised: #1b2130;
        --hairline: #2a3346;
        --hairline-soft: #222a3a;
        --ink: #eaedf5;
        --body: #c7ced9;
        --dim: #7e889f;
        --signal: #ff9f45;
        --signal-hot: #ffc978;
        --mono: ui-monospace, "SF Mono", "JetBrains Mono", "Fira Code",
          "Cascadia Code", monospace;
        --sans: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        --serif: "Iowan Old Style", "Palatino Linotype", "Book Antiqua",
          Palatino, "Source Serif 4", "Georgia", serif;
        --measure: 34rem;
      }

      * {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
      }

      body {
        margin: 0;
        background-color: var(--void);
        background-image:
          radial-gradient(
            120% 80% at 50% -10%,
            #1a2030 0%,
            var(--void) 60%
          ),
          repeating-linear-gradient(
            0deg,
            rgba(255, 255, 255, 0.012) 0,
            rgba(255, 255, 255, 0.012) 1px,
            transparent 1px,
            transparent 3px
          );
        color: var(--body);
        font-family: var(--serif);
        line-height: 1.72;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .bench {
        min-height: 100vh;
        padding: clamp(1.5rem, 5vw, 4rem) clamp(1rem, 4vw, 2rem) 4rem;
      }

      .lesson {
        max-width: 54rem;
        margin: 0 auto;
      }

      /* --- Hero -------------------------------------------------------------- */
      .lesson__hero {
        padding: clamp(1rem, 4vw, 3rem) 0 clamp(2rem, 5vw, 3.5rem);
        border-bottom: 1px solid var(--hairline);
      }

      .lesson__eyebrow {
        margin: 0 0 1.4rem;
        font-family: var(--mono);
        font-size: 0.74rem;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--signal);
      }

      .lesson__title {
        margin: 0;
        font-family: var(--serif);
        font-weight: 600;
        font-size: clamp(2.3rem, 7vw, 4rem);
        line-height: 1.04;
        letter-spacing: -0.015em;
        color: var(--ink);
      }

      .lesson__thesis {
        max-width: var(--measure);
        margin: 1.5rem 0 0;
        font-size: clamp(1.1rem, 2.4vw, 1.35rem);
        line-height: 1.6;
        color: var(--body);
      }

      /* Three simultaneous taps — the SVF's signature, drawn in CSS. */
      .lesson__taps {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        margin-top: 2.2rem;
        font-family: var(--mono);
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--dim);
      }

      .lesson__tap-in {
        color: var(--body);
      }

      .lesson__tap-fan {
        width: 2.4rem;
        height: 1px;
        background: linear-gradient(90deg, var(--dim), var(--signal));
        box-shadow: 0 0 8px rgba(255, 159, 69, 0.4);
      }

      .lesson__tap-out {
        padding: 0.2rem 0.5rem;
        border: 1px solid color-mix(in srgb, var(--signal) 45%, transparent);
        border-radius: 999px;
        color: var(--signal-hot);
      }

      /* --- The tab bank: an instrument channel selector --------------------- */
      /* Sticky so the whole six-part structure stays visible + navigable while
         reading a long panel. The bank sits on a raised faceplate; the rail
         gradient survives as a horizontal "signal bus" under it. */
      .tabs {
        position: sticky;
        top: 0;
        z-index: 5;
        margin: clamp(1.4rem, 4vw, 2.2rem) 0 clamp(1.8rem, 4vw, 2.6rem);
        padding: 0.75rem 0 0.55rem;
        background: linear-gradient(180deg, var(--void) 62%, transparent);
      }

      /* Horizontal scroll on narrow screens; the tablist itself stays intact
         (roving-tabindex keyboard nav reveals off-screen tabs). */
      .tabs__scroll {
        overflow-x: auto;
        overflow-y: hidden;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
      }
      .tabs__scroll::-webkit-scrollbar {
        display: none;
      }

      .tabs__bank {
        display: inline-flex;
        gap: 0.35rem;
        min-width: 100%;
        padding: 0.4rem;
        background: linear-gradient(180deg, var(--raised), var(--face));
        border-radius: 14px;
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.04),
          inset 0 0 0 1px var(--hairline),
          0 12px 26px -20px rgba(0, 0, 0, 0.9);
      }

      /* One engraved push-button. The index (01..06) keeps the ordinal cue the
         old rail carried; the LED lights amber when the channel is selected. */
      .tab {
        position: relative;
        display: inline-flex;
        flex-direction: column;
        gap: 0.34rem;
        flex: 1 1 auto;
        min-width: max-content;
        padding: 0.6rem 0.85rem 0.68rem;
        border: none;
        border-radius: 10px;
        background: transparent;
        color: var(--dim);
        font-family: var(--mono);
        text-align: left;
        cursor: pointer;
        transition:
          background 140ms ease,
          color 140ms ease,
          box-shadow 140ms ease;
      }

      .tab__meta {
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }

      .tab__led {
        width: 0.42rem;
        height: 0.42rem;
        border-radius: 50%;
        background: var(--hairline);
        box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.45);
        transition: background 140ms ease, box-shadow 140ms ease;
      }

      .tab__index {
        font-size: 0.62rem;
        letter-spacing: 0.12em;
        font-variant-numeric: tabular-nums;
        color: var(--dim);
        opacity: 0.75;
      }

      .tab__label {
        font-size: 0.76rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        white-space: nowrap;
        color: inherit;
      }

      .tab:hover {
        color: var(--body);
        background: color-mix(in srgb, var(--signal) 6%, transparent);
      }

      /* Hands-on channels (Play / Build) glow a warm ember even when idle. */
      .tab--hot .tab__led {
        background: color-mix(in srgb, var(--signal) 42%, var(--hairline));
        box-shadow: 0 0 5px rgba(255, 159, 69, 0.28);
      }
      .tab--hot .tab__index {
        color: color-mix(in srgb, var(--signal) 55%, var(--dim));
        opacity: 0.9;
      }

      /* Selected channel: the button lifts and lights. */
      .tab[aria-selected="true"] {
        color: var(--ink);
        background: linear-gradient(180deg, #232b3e, var(--face));
        box-shadow:
          inset 0 0 0 1px color-mix(in srgb, var(--signal) 32%, var(--hairline)),
          0 6px 14px -10px rgba(0, 0, 0, 0.9);
      }
      .tab[aria-selected="true"] .tab__index {
        color: var(--signal);
        opacity: 1;
      }
      .tab[aria-selected="true"] .tab__label {
        color: var(--ink);
      }
      .tab[aria-selected="true"] .tab__led {
        background: radial-gradient(circle at 40% 35%, var(--signal-hot), var(--signal) 70%);
        box-shadow: 0 0 8px rgba(255, 159, 69, 0.7);
      }
      .tab--hot[aria-selected="true"] .tab__led {
        box-shadow: 0 0 13px rgba(255, 159, 69, 0.85);
      }

      .tab:focus-visible {
        outline: 2px solid var(--signal-hot);
        outline-offset: 2px;
      }

      /* The signal bus: the old vertical rail's cool -> amber-hot gradient, laid
         flat under the bank — cool at Concept (left), hot through Play / Build,
         cooling into Go deeper (right). */
      .tabs__bus {
        height: 2px;
        margin-top: 0.5rem;
        border-radius: 2px;
        background: linear-gradient(
          90deg,
          var(--hairline) 0%,
          var(--hairline) 22%,
          color-mix(in srgb, var(--signal) 30%, var(--hairline)) 44%,
          color-mix(in srgb, var(--signal) 72%, var(--hairline)) 64%,
          var(--signal) 80%,
          color-mix(in srgb, var(--signal) 42%, var(--hairline)) 100%
        );
      }

      /* --- Body ------------------------------------------------------------- */
      .lesson__body {
        position: relative;
      }

      /* --- Prose inside a part --------------------------------------------- */
      .lesson__body :where(p, ul, ol) {
        max-width: var(--measure);
      }

      .lesson__body p {
        font-size: 1.12rem;
        margin: 0 0 1.15rem;
        color: var(--body);
      }

      .lesson__body :where(ul, ol) {
        padding-left: 1.2rem;
        margin: 0 0 1.15rem;
      }

      .lesson__body li {
        margin: 0 0 0.5rem;
        font-size: 1.08rem;
      }

      .lesson__body li::marker {
        color: var(--signal);
      }

      .lesson__body strong {
        color: var(--ink);
        font-weight: 600;
      }

      .lesson__body em {
        color: var(--signal-hot);
        font-style: italic;
      }

      /* Inline code + engraved terms borrow the instrument's monospace voice. */
      .lesson__body :not(pre) > code {
        font-family: var(--mono);
        font-size: 0.86em;
        color: var(--signal-hot);
        background: color-mix(in srgb, var(--signal) 9%, var(--void));
        border: 1px solid var(--hairline-soft);
        border-radius: 5px;
        padding: 0.08em 0.38em;
        white-space: nowrap;
      }

      .lesson__body h3 {
        max-width: var(--measure);
        margin: 2.1rem 0 0.7rem;
        font-family: var(--serif);
        font-weight: 600;
        font-size: 1.4rem;
        line-height: 1.25;
        color: var(--ink);
      }

      .lesson__body a:not(.gd__card) {
        color: var(--signal-hot);
        text-underline-offset: 3px;
        text-decoration-color: color-mix(in srgb, var(--signal) 55%, transparent);
      }

      .lesson__body a:not(.gd__card):hover {
        text-decoration-color: var(--signal);
      }

      /* --- Footer ----------------------------------------------------------- */
      .lesson__foot {
        margin-top: 3.5rem;
        padding-top: 1.6rem;
        border-top: 1px solid var(--hairline);
      }

      .lesson__foot-line {
        max-width: var(--measure);
        margin: 0;
        font-family: var(--mono);
        font-size: 0.78rem;
        line-height: 1.7;
        letter-spacing: 0.02em;
        color: var(--dim);
      }

      :where(a, button, input):focus-visible {
        outline: 2px solid var(--signal-hot);
        outline-offset: 2px;
      }

      @media (max-width: 34rem) {
        .tab {
          padding: 0.55rem 0.7rem 0.62rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .tab,
        .tab__led {
          transition: none;
        }
      }
    </style>
  </body>
</html>
