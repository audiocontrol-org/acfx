---
// CheckpointLadder — the build-along checkpoints inside the "Build it" tab.
// Renders the enumerated build milestones (`build-checkpoints.ts`), each a REAL
// repository milestone the SVF travelled on its lab -> primitive -> effect ->
// adapter climb, with the real path it lives at and a concrete way to verify
// the state is green. History replayed, not invented tutorial steps.
//
// Presented as a SIMPLE ordered list of steps (frontend-design — tabbed
// layout): the old vertical "signal rail" connector was removed because it
// competed with the outer numbering. Now the outer sequence is the tab bank
// (01..06) and this is a plain 01..04 step list inside the Build tab — one
// numbering per axis, no nested rails.
import { svfBuildCheckpoints } from '../../content/svf/build-checkpoints.ts';
import CodeViewer from './CodeViewer.astro';

const rungs = svfBuildCheckpoints;
---

<ol class="steps">
  {
    rungs.map((rung, i) => (
      <li class="step">
        <div class="step__head">
          <span class="step__num">{String(i + 1).padStart(2, '0')}</span>
          <span class="step__stage">{rung.stage}</span>
          <h3 class="step__title">{rung.title}</h3>
        </div>
        <code class="step__path">{rung.repoPath}</code>
        <p class="step__milestone">{rung.milestone}</p>
        <CodeViewer code={rung.code} />
        <p class="step__verify">
          <span class="step__verify-key">verify</span>
          {rung.verify}
        </p>
      </li>
    ))
  }
</ol>

<style>
  .steps {
    list-style: none;
    margin: 1.5rem 0 0.5rem;
    padding: 0;
    display: grid;
    gap: 0.85rem;
    counter-reset: none;
  }

  .step {
    background: linear-gradient(180deg, var(--raised), var(--face));
    border-radius: 12px;
    box-shadow: inset 0 0 0 1px var(--hairline), 0 14px 30px -22px rgba(0, 0, 0, 0.9);
    padding: 1rem 1.15rem 1.1rem;
  }

  .step__head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin-bottom: 0.6rem;
  }

  /* The step index — engraved, amber, but a plain enumerator (no rail node). */
  .step__num {
    font-family: var(--mono);
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.1em;
    color: var(--signal);
  }

  .step__stage {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--void);
    background: radial-gradient(circle at 40% 30%, var(--signal-hot), var(--signal) 78%);
    border-radius: 999px;
    padding: 0.18rem 0.6rem;
  }

  .step__title {
    margin: 0;
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.28rem;
    line-height: 1.2;
    color: var(--ink);
  }

  .step__path {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--signal-hot);
    background: color-mix(in srgb, var(--signal) 9%, var(--void));
    border: 1px solid var(--hairline-soft);
    border-radius: 5px;
    padding: 0.12rem 0.45rem;
    margin-bottom: 0.7rem;
    word-break: break-all;
  }

  .step__milestone {
    margin: 0 0 0.7rem;
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--body);
  }

  .step__verify {
    margin: 0;
    padding-top: 0.65rem;
    border-top: 1px solid var(--hairline-soft);
    font-family: var(--mono);
    font-size: 0.8rem;
    line-height: 1.65;
    color: var(--dim);
  }

  .step__verify-key {
    display: inline-block;
    margin-right: 0.55rem;
    color: var(--signal);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.68rem;
  }

  @media (max-width: 34rem) {
    .step__title {
      flex-basis: 100%;
    }
  }
</style>
