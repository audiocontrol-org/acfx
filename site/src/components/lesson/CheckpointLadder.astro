---
// CheckpointLadder — the "Build it with acfx" ladder (Part 5). Renders the
// enumerated build-along checkpoints (`build-checkpoints.ts`), each a REAL
// repository milestone the SVF travelled on its lab -> primitive -> effect ->
// adapter climb, with the real path it lives at and a concrete way to verify
// the state is green. This is the enumerated list the spec's US2 build-along
// calls for (addresses analyze finding U1) — history replayed, not invented
// tutorial steps.
import { svfBuildCheckpoints } from '../../content/svf/build-checkpoints.ts';

const rungs = svfBuildCheckpoints;
---

<ol class="ladder">
  {
    rungs.map((rung, i) => (
      <li class="ladder__rung">
        <div class="ladder__mark" aria-hidden="true">
          <span class="ladder__dot" />
          <span class="ladder__stage">{rung.stage}</span>
        </div>
        <div class="ladder__card">
          <div class="ladder__top">
            <span class="ladder__step">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="ladder__title">{rung.title}</h3>
          </div>
          <code class="ladder__path">{rung.repoPath}</code>
          <p class="ladder__milestone">{rung.milestone}</p>
          <p class="ladder__verify">
            <span class="ladder__verify-key">verify</span>
            {rung.verify}
          </p>
        </div>
      </li>
    ))
  }
</ol>

<style>
  .ladder {
    list-style: none;
    counter-reset: none;
    margin: 1.5rem 0 0.5rem;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .ladder__rung {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    gap: 1rem;
    position: relative;
    padding-bottom: 1.1rem;
  }

  /* The rung's own mini-rail connector, echoing the page signal rail. */
  .ladder__rung:not(:last-child)::before {
    content: "";
    position: absolute;
    left: calc(0.52rem);
    top: 1.4rem;
    bottom: -0.1rem;
    width: 2px;
    background: linear-gradient(180deg, var(--signal), color-mix(in srgb, var(--signal) 25%, var(--hairline)));
  }

  .ladder__mark {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    padding-top: 0.15rem;
  }

  .ladder__dot {
    width: 1.05rem;
    height: 1.05rem;
    border-radius: 50%;
    background: radial-gradient(circle at 38% 32%, var(--signal-hot), var(--signal) 72%);
    box-shadow: 0 0 12px rgba(255, 159, 69, 0.5), inset 0 0 0 2px rgba(12, 15, 22, 0.55);
    margin-left: 0.02rem;
  }

  .ladder__stage {
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dim);
  }

  .ladder__card {
    background: linear-gradient(180deg, var(--raised), var(--face));
    border-radius: 12px;
    box-shadow: inset 0 0 0 1px var(--hairline), 0 14px 30px -22px rgba(0, 0, 0, 0.9);
    padding: 1rem 1.15rem 1.1rem;
    margin-bottom: 0.2rem;
  }

  .ladder__top {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    margin-bottom: 0.55rem;
  }

  .ladder__step {
    font-family: var(--mono);
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.1em;
    color: var(--signal);
  }

  .ladder__title {
    margin: 0;
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.28rem;
    line-height: 1.2;
    color: var(--ink);
  }

  .ladder__path {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--signal-hot);
    background: color-mix(in srgb, var(--signal) 9%, var(--void));
    border: 1px solid var(--hairline-soft);
    border-radius: 5px;
    padding: 0.12rem 0.45rem;
    margin-bottom: 0.7rem;
    word-break: break-all;
  }

  .ladder__milestone {
    margin: 0 0 0.7rem;
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--body);
  }

  .ladder__verify {
    margin: 0;
    padding-top: 0.65rem;
    border-top: 1px solid var(--hairline-soft);
    font-family: var(--mono);
    font-size: 0.8rem;
    line-height: 1.65;
    color: var(--dim);
  }

  .ladder__verify-key {
    display: inline-block;
    margin-right: 0.55rem;
    color: var(--signal);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.68rem;
  }

  @media (max-width: 34rem) {
    .ladder__rung {
      grid-template-columns: 1fr;
      gap: 0.55rem;
    }
    .ladder__rung:not(:last-child)::before {
      display: none;
    }
    .ladder__mark {
      flex-direction: row;
      align-items: center;
      gap: 0.6rem;
    }
  }
</style>
