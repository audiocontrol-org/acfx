---
// LessonPart — one tabpanel of the six-part anatomy (frontend-design — tabbed
// layout). The six parts are one ordered procedure; the ORDER now lives in the
// tab bank's station index (01..06, rendered by LessonLayout from
// `lesson-parts.ts`), so a part no longer carries its own numbered rail node —
// that removed the nested-numbering weirdness (the old station 05 held its own
// 01..04 rail).
//
// Each part is a `role="tabpanel"` labelled by its tab button (`${id}-tab`).
// `id` is the stable anchor the deep-link hash + "Go deeper" links + the
// Playwright test resolve. Exactly one part is server-rendered active (visible);
// the rest start `hidden`, and the tab controller toggles `hidden` on switch
// WITHOUT unmounting the live artifact islands inside.
interface Props {
  readonly id: string;
  readonly kicker: string;
  readonly title: string;
  /** The one part rendered visible on load (the first tab). */
  readonly active?: boolean;
}

const { id, kicker, title, active = false } = Astro.props;
---

<section
  class="part"
  id={id}
  role="tabpanel"
  aria-labelledby={`${id}-tab`}
  tabindex="0"
  hidden={!active}
>
  <header class="part__head">
    <p class="part__kicker">{kicker}</p>
    <h2 class="part__title" id={`${id}-title`}>{title}</h2>
  </header>
  <div class="part__content">
    <slot />
  </div>
</section>

<style>
  .part {
    padding: clamp(0.4rem, 2vw, 1rem) 0 0.4rem;
  }

  /* Gentle reveal each time a panel becomes the active tab. Runs on show
     because the controller toggles `hidden` (display:none -> block). */
  .part:not([hidden]) {
    animation: part-in 220ms cubic-bezier(0.22, 0.61, 0.36, 1) both;
  }

  @keyframes part-in {
    from {
      opacity: 0;
      transform: translateY(5px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* The tabpanel is focusable (deep-link / keyboard target) but shouldn't show a
     focus ring on programmatic/pointer focus — only real keyboard focus. */
  .part:focus {
    outline: none;
  }
  .part:focus-visible {
    outline: 2px solid var(--signal-hot);
    outline-offset: 6px;
    border-radius: 4px;
  }

  .part__head {
    margin-bottom: 1.3rem;
  }

  .part__kicker {
    margin: 0 0 0.5rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--signal);
  }

  .part__title {
    max-width: var(--measure);
    margin: 0;
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(1.7rem, 4.5vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.012em;
    color: var(--ink);
  }

  .part__content {
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .part:not([hidden]) {
      animation: none;
    }
  }
</style>
