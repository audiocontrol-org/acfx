---
// MathWell — an engraved "screen behind glass" for math (the recurrence, the
// transfer-function idea). Reuses the instruments' analyzer-well vocabulary
// (dark inset, hairline, monospace, amber) so displayed math reads like a
// reading off the same bench. Presentation only; the content is authored in
// the MDX slot as monospace lines.
interface Props {
  readonly label: string;
  /** Optional trailing note shown dim, right-aligned in the caption. */
  readonly note?: string;
}

const { label, note } = Astro.props;
---

<figure class="well">
  <figcaption class="well__label">
    <span>{label}</span>
    {note ? <span class="well__note">{note}</span> : null}
  </figcaption>
  <div class="well__screen">
    <slot />
  </div>
</figure>

<style>
  .well {
    max-width: var(--measure);
    margin: 1.5rem 0 1.7rem;
  }

  .well__label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.6rem;
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 0.4rem;
  }

  .well__note {
    letter-spacing: 0.08em;
    text-transform: none;
    color: var(--dim);
    font-size: 0.66rem;
  }

  .well__screen {
    background: #0c0f16;
    border-radius: 10px;
    box-shadow: inset 0 0 0 1px var(--hairline), inset 0 2px 14px rgba(0, 0, 0, 0.7);
    padding: 1.05rem 1.15rem;
    overflow-x: auto;
  }

  /* Math lines are authored as a <pre> in the slot; keep them engraved-amber. */
  .well__screen :global(pre) {
    margin: 0;
    font-family: var(--mono);
    font-size: 0.92rem;
    line-height: 1.85;
    color: var(--signal-hot);
    white-space: pre;
  }

  .well__screen :global(pre b),
  .well__screen :global(pre strong) {
    color: var(--ink);
    font-weight: 600;
  }

  .well__screen :global(pre .dim) {
    color: var(--dim);
  }
</style>
