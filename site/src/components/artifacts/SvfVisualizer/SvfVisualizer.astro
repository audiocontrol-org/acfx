---
// SvfVisualizer — the "Observe it" live analysis artifact (T029/T030).
//
// Three instrument wells — frequency response, z-plane pole/zero, impulse
// response — painted live from the REAL compiled analysis ABI (adapters/web
// loader `SvfModule`: getFrequencyResponse / getPoleZero / renderImpulse) as
// the learner sweeps cutoff / resonance / mode. No filter math runs in TS
// (FR-003, Principle VII); the client island only presents the compiled
// target's own output.
//
// Visual direction (/frontend-design + /dataviz): the SAME analog-instrument
// faceplate as SvfDemo (deep blue-graphite enclosure, engraved monospace,
// one warm signal-amber accent) reframed as a BENCH ANALYZER — three engraved
// "screens" behind glass. The shared signature is the resonance-heat: as
// resonance rises the pole marches toward the unit circle and the amber traces
// + that pole glow hotter, tying the picture to the physics (pole radius ->
// resonance) exactly as SvfDemo's faceplate heats up.
//
// Progressive enhancement: the server renders the content fallback (real
// pre-generated response + impulse from the manifest) visible; the island
// reveals the live analyzer only when WebAssembly is present, and on a
// load failure shows a visible descriptive error and the static snapshot
// (FR-015). A DSP fallback (re-derived filter) is never substituted.
import type { SvfVisualizerProps } from '@lib/artifacts/registry';
import { assetsByKind } from '@lib/lesson-assets/manifest';
import { cutoffHzToNormalized, formatCutoff, formatResonance, modeLabel } from '../SvfDemo/svf-param-map.ts';
import type { SvfDemoMode } from '../SvfDemo/svf-param-map.ts';

const { cutoffHz, resonance, mode } = Astro.props as SvfVisualizerProps;

// The analyzer needs an ANALYSIS-capable wasm (getFrequencyResponse/getPoleZero/
// renderImpulse): the manifest wasm asset advertising the "analysis"
// capability (a CDN url — FR-014, T031). The controller loads it glue-free at
// runtime (adapters/web/analysis/svf-analysis-wasm.ts) — no `build/web`
// dependency. If no such asset is published, the controller falls back to the
// static content snapshot with a visible error (FR-015).
const analysisWasm = assetsByKind('wasm').find((a) => a.capabilities?.includes('analysis') === true);
const analysisWasmUrl = analysisWasm?.url;
const initialCutoffNorm = cutoffHzToNormalized(cutoffHz);
const uiMode: SvfDemoMode = mode;

// Pick the content-fallback assets (real pre-generated core output) whose
// params best match this artifact's initial setting; fall back to the first.
function pickByCutoff(kind: 'response' | 'impulse'): string | undefined {
  const entries = assetsByKind(kind);
  let best = entries[0];
  if (best === undefined) return undefined;
  for (const entry of entries) {
    const target = entry.params?.['cutoffHz'];
    const bestTarget = best.params?.['cutoffHz'];
    if (target === undefined) continue;
    if (bestTarget === undefined || Math.abs(target - cutoffHz) < Math.abs(bestTarget - cutoffHz)) {
      best = entry;
    }
  }
  return best.url;
}

const responseUrl = pickByCutoff('response');
const impulseUrl = pickByCutoff('impulse');

const uid = Math.random().toString(36).slice(2, 8);
const cutoffId = `vz-cutoff-${uid}`;
const resId = `vz-res-${uid}`;
---

<div
  class="vz"
  data-svf-visualizer
  data-analysis-wasm-url={analysisWasmUrl}
  data-response-url={responseUrl}
  data-impulse-url={impulseUrl}
  data-initial-cutoff-hz={String(cutoffHz)}
  data-initial-resonance={String(resonance)}
  data-initial-mode={uiMode}
  style={`--vz-glow:${resonance.toFixed(3)}`}
>
  <div class="vz__panel">
    <header class="vz__head">
      <span class="vz__eyebrow">SVF Analyzer</span>
      <span class="vz__status" data-role="status" role="status" aria-live="polite">Initializing…</span>
      <span class="vz__badge">real analysis ABI</span>
    </header>

    <p class="vz__error" data-role="error" role="alert" hidden></p>

    <!-- Live analyzer — revealed once the island confirms WASM support. -->
    <section class="vz__live" data-role="live" hidden>
      <div class="vz__wells">
        <figure class="vz__well">
          <figcaption class="vz__well-label">Frequency response<span>magnitude · dB</span></figcaption>
          <canvas class="vz__canvas" data-role="plot-response"></canvas>
        </figure>
        <figure class="vz__well vz__well--square">
          <figcaption class="vz__well-label">Poles &amp; zeros<span>z-plane · <span data-role="radius-readout">—</span> |p|</span></figcaption>
          <canvas class="vz__canvas" data-role="plot-polezero"></canvas>
        </figure>
        <figure class="vz__well">
          <figcaption class="vz__well-label">Impulse response<span>amplitude · samples</span></figcaption>
          <canvas class="vz__canvas" data-role="plot-impulse"></canvas>
        </figure>
      </div>

      <div class="vz__readouts">
        <div class="vz__reado">
          <span class="vz__reado-value" data-role="cutoff-readout">{formatCutoff(cutoffHz)}</span>
          <span class="vz__reado-label">cutoff</span>
        </div>
        <div class="vz__reado">
          <span class="vz__reado-value" data-role="resonance-readout">{formatResonance(resonance)}</span>
          <span class="vz__reado-label">resonance</span>
        </div>
        <div class="vz__reado">
          <span class="vz__reado-value" data-role="mode-readout">{modeLabel(uiMode)}</span>
          <span class="vz__reado-label">mode</span>
        </div>
      </div>

      <div class="vz__controls">
        <div class="vz__fader">
          <label class="vz__ctl-label" for={cutoffId}>Cutoff</label>
          <input
            id={cutoffId}
            class="vz__range"
            data-role="cutoff"
            type="range"
            min="0"
            max="1"
            step="0.001"
            value={String(initialCutoffNorm)}
            aria-label="Cutoff frequency, 20 Hz to 20 kHz"
          />
          <span class="vz__scale">20 Hz — 20 kHz</span>
        </div>

        <div class="vz__fader">
          <label class="vz__ctl-label" for={resId}>Resonance</label>
          <input
            id={resId}
            class="vz__range vz__range--res"
            data-role="resonance"
            type="range"
            min="0"
            max="1"
            step="0.01"
            value={String(resonance)}
            aria-label="Resonance, 0 to 1"
          />
          <span class="vz__scale">calm — self-oscillating</span>
        </div>

        <div class="vz__modes" role="group" aria-label="Filter mode">
          <span class="vz__ctl-label">Mode</span>
          <div class="vz__seg">
            <button class="vz__seg-btn" data-role="mode" data-mode="lowpass" type="button" aria-pressed="true">LP</button>
            <button class="vz__seg-btn" data-role="mode" data-mode="highpass" type="button" aria-pressed="false">HP</button>
            <button class="vz__seg-btn" data-role="mode" data-mode="bandpass" type="button" aria-pressed="false">BP</button>
          </div>
        </div>
      </div>
    </section>

    <!-- Content fallback: real pre-generated core output, drawn client-side. -->
    <section class="vz__fallback" data-role="fallback">
      <p class="vz__fallback-note">
        Pre-generated analysis of the real filter.
        <span class="vz__fallback-sub">The live, interactive analyzer loads when your browser supports WebAssembly.</span>
      </p>
      <div class="vz__wells">
        <figure class="vz__well">
          <figcaption class="vz__well-label">Frequency response<span>magnitude · dB</span></figcaption>
          <canvas class="vz__canvas" data-role="fallback-response"></canvas>
        </figure>
        <figure class="vz__well vz__well--square">
          <figcaption class="vz__well-label">Poles &amp; zeros<span>live only</span></figcaption>
          <canvas class="vz__canvas" data-role="fallback-polezero"></canvas>
        </figure>
        <figure class="vz__well">
          <figcaption class="vz__well-label">Impulse response<span>amplitude · samples</span></figcaption>
          <canvas class="vz__canvas" data-role="fallback-impulse"></canvas>
        </figure>
      </div>
    </section>
  </div>
</div>

<script>
  import { initSvfVisualizers } from './svf-visualizer-controller.ts';
  initSvfVisualizers();
</script>

<style>
  .vz {
    --void: #0f1219;
    --face: #1b2130;
    --raised: #252c3e;
    --hairline: #333c52;
    --ink: #eaedf5;
    --dim: #7e889f;
    --signal: #ff9f45;
    --signal-hot: #ffc978;
    /* Analyzer-well tokens (screens behind glass). */
    --vz-well: #0c0f16;
    --vz-grid: #232b3d;
    --vz-axis: #3a4560;
    --vz-cool: #6fb6d6;
    --mono: ui-monospace, "SF Mono", "JetBrains Mono", "Fira Code", "Cascadia Code", monospace;
    --sans: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;

    display: block;
    color: var(--ink);
    font-family: var(--sans);
    container-type: inline-size;
  }

  .vz__panel {
    background: linear-gradient(180deg, #202638 0%, var(--face) 55%, #171c29 100%);
    border-radius: 16px;
    padding: clamp(1.1rem, 3.5cqi, 1.9rem);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      inset 0 0 0 1px var(--hairline),
      0 24px 48px -24px rgba(0, 0, 0, 0.85),
      0 0 calc(var(--vz-glow, 0) * 46px) rgba(255, 159, 69, calc(var(--vz-glow, 0) * 0.28));
    transition: box-shadow 160ms ease;
  }

  .vz__head {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-bottom: 0.9rem;
    margin-bottom: 1.1rem;
    border-bottom: 1px solid var(--hairline);
  }

  .vz__eyebrow {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dim);
  }

  .vz__status {
    flex: 1;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--dim);
    text-align: center;
  }

  .vz__badge {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--signal);
    border: 1px solid color-mix(in srgb, var(--signal) 40%, transparent);
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
    white-space: nowrap;
  }

  .vz__error {
    font-family: var(--mono);
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--signal-hot);
    background: color-mix(in srgb, var(--signal) 12%, var(--void));
    border: 1px solid color-mix(in srgb, var(--signal) 45%, transparent);
    border-radius: 8px;
    padding: 0.6rem 0.8rem;
    margin: 0 0 1rem;
  }

  /* --- Wells ------------------------------------------------------------- */
  .vz__wells {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-auto-rows: minmax(0, auto);
    gap: 0.8rem;
  }

  .vz__well {
    margin: 0;
    background: var(--vz-well);
    border-radius: 10px;
    box-shadow: inset 0 0 0 1px var(--hairline), inset 0 2px 14px rgba(0, 0, 0, 0.7);
    padding: 0.6rem 0.65rem 0.45rem;
    overflow: hidden;
  }

  /* Frequency + impulse span the full width; the z-plane sits square beside. */
  .vz__well:nth-child(1) {
    grid-column: 1;
    grid-row: 1;
  }
  .vz__well--square {
    grid-column: 2;
    grid-row: 1 / span 2;
    display: flex;
    flex-direction: column;
  }
  .vz__well:nth-child(3) {
    grid-column: 1;
    grid-row: 2;
  }

  .vz__well-label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 0.35rem;
  }

  .vz__well-label span {
    letter-spacing: 0.08em;
    text-transform: none;
    color: var(--dim);
    font-size: 0.62rem;
  }

  .vz__canvas {
    display: block;
    width: 100%;
    height: 160px;
  }

  .vz__well--square .vz__canvas {
    flex: 1;
    height: auto;
    min-height: 220px;
    aspect-ratio: 1 / 1;
  }

  /* --- Readouts ---------------------------------------------------------- */
  .vz__readouts {
    display: flex;
    gap: 1.6rem;
    margin: 1.2rem 0 0.2rem;
    flex-wrap: wrap;
  }

  .vz__reado {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .vz__reado-value {
    font-family: var(--mono);
    font-variant-numeric: tabular-nums;
    font-size: 1.2rem;
    color: var(--signal-hot);
    text-shadow: 0 0 calc(4px + var(--vz-glow, 0) * 20px) rgba(255, 159, 69, calc(0.1 + var(--vz-glow, 0) * 0.5));
    transition: text-shadow 160ms ease;
  }

  .vz__reado-label {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dim);
  }

  /* --- Controls (shared vocabulary with SvfDemo) ------------------------- */
  .vz__controls {
    display: grid;
    gap: 1.1rem;
    margin-top: 1.2rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--hairline);
  }

  .vz__fader {
    display: grid;
    grid-template-columns: 6.5rem 1fr auto;
    align-items: center;
    gap: 0.9rem;
  }

  .vz__ctl-label {
    font-family: var(--mono);
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .vz__scale {
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    color: var(--dim);
    white-space: nowrap;
  }

  .vz__range {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 0.5rem;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--raised), #2f3750);
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.6);
    cursor: pointer;
  }

  .vz__range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 1.15rem;
    height: 1.15rem;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, var(--signal-hot), var(--signal) 70%);
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.4), 0 0 12px rgba(255, 159, 69, 0.6);
    cursor: grab;
  }

  .vz__range::-moz-range-thumb {
    width: 1.15rem;
    height: 1.15rem;
    border: none;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, var(--signal-hot), var(--signal) 70%);
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.4), 0 0 12px rgba(255, 159, 69, 0.6);
    cursor: grab;
  }

  .vz__range--res::-webkit-slider-thumb {
    background: radial-gradient(circle at 35% 30%, #ffd9a3, var(--signal) 70%);
  }

  .vz__modes {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    align-items: center;
    gap: 0.9rem;
  }

  .vz__seg {
    display: inline-flex;
    background: var(--void);
    border-radius: 10px;
    padding: 0.25rem;
    box-shadow: inset 0 0 0 1px var(--hairline);
    width: fit-content;
  }

  .vz__seg-btn {
    font-family: var(--mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--dim);
    background: transparent;
    border: none;
    border-radius: 7px;
    padding: 0.5rem 1.1rem;
    cursor: pointer;
    transition: color 120ms ease, background 120ms ease;
  }

  .vz__seg-btn:hover {
    color: var(--ink);
  }

  .vz__seg-btn[aria-pressed="true"] {
    color: var(--void);
    background: linear-gradient(180deg, var(--signal-hot), var(--signal));
    box-shadow: 0 0 10px rgba(255, 159, 69, 0.4);
  }

  /* --- Content fallback -------------------------------------------------- */
  .vz__fallback-note {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 1rem;
  }

  .vz__fallback-sub {
    display: block;
    font-size: 0.8rem;
    color: var(--dim);
    margin-top: 0.25rem;
  }

  /* --- Focus + responsive + motion -------------------------------------- */
  .vz__seg-btn:focus-visible,
  .vz__range:focus-visible {
    outline: 2px solid var(--signal-hot);
    outline-offset: 2px;
  }

  @container (max-width: 34rem) {
    .vz__wells {
      grid-template-columns: 1fr;
    }
    .vz__well:nth-child(1),
    .vz__well:nth-child(3),
    .vz__well--square {
      grid-column: 1;
      grid-row: auto;
    }
    .vz__fader,
    .vz__modes {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
    .vz__scale {
      justify-self: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .vz__panel,
    .vz__reado-value {
      transition: none;
    }
  }
</style>
