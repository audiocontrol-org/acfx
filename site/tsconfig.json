{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["src/lib/*"],
      "@content/*": ["src/content/*"],
      "@components/*": ["src/components/*"],
      "@acfx/web/*": ["../adapters/web/*"]
    }
  },
  "include": [".astro/types.d.ts", "src/**/*", "playwright.config.ts", "tests/**/*"],
  "exclude": ["dist", "test-results", "playwright-report"]
}
